@{
    ViewData["Title"] = "About";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center mb-5">
                <div class="display-4 text-primary mb-3">
                    <i class="bi bi-wallet2"></i>
                </div>
                <h1 class="fw-bold">About SpendWise</h1>
                <p class="lead text-muted">An intelligent tool to simplify how you manage and visualize your money.</p>
            </div>

            <h4 class="fw-bold mb-4 mt-5">Core Features</h4>
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <i class="bi bi-graph-up-arrow fs-3 text-success mb-2"></i>
                            <h5 class="fw-bold">Smart Insights</h5>
                            <p class="small text-muted">Uses linear projection to forecast your month-end spending based
                                on current daily averages.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-body">
                                <i class="bi bi-layers-half fs-3 text-info mb-2"></i>
                                <h5 class="fw-bold">Hybrid Tracking</h5>
                                <p class="small text-muted">A unified database for one-time costs and subscriptions using C#
                                    Polymorphism.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="card-body">
                                    <i class="bi bi-pie-chart-fill fs-3 text-warning mb-2"></i>
                                    <h5 class="fw-bold">Category Analytics</h5>
                                    <p class="small text-muted">Visual breakdown of spending across Health, Tech, Food, and
                                        more.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card h-100 shadow-sm border-0">
                                    <div class="card-body">
                                        <i class="bi bi-database-check fs-3 text-primary mb-2"></i>
                                        <h5 class="fw-bold">Reliable Storage</h5>
                                        <p class="small text-muted">Backed by SQL Server with Entity Framework Core for robust data
                                            integrity.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-5 pt-5 border-top">
                                <div class="row align-items-center">
                                    <div class="col-md-4 text-center mb-4 mb-md-0">
                                        <img src="/imgprojecticon/ben.png"
                                             class="rounded-circle shadow-sm border border-4 border-white" alt="Creator Portrait"
                                             style="width: 150px; height: 150px; object-fit: cover;">
                                    </div>
                                    <div class="col-md-8">
                                        <h4 class="fw-bold mb-2">Meet the Developer</h4>
                                        <p class="text-muted mb-3">
                                            Hi, I'm Almelben Pabia. I built SpendWise to bridge the gap between complex financial
                                            software and simple spreadsheets.
                                            My goal was to create a tool that not only tracks where money goes but uses data to help
                                            users predict where it's heading.
                                        </p>
                                        <div class="d-flex gap-3">
                                            <a href="https://github.com/ben86-glitch" class="btn btn-outline-dark btn-sm">
                                                <i class="bi bi-github"></i> GitHub
                                            </a>
                                            <a href="https://www.linkedin.com/in/almelben-pabia-39b1593a6/"
                                                   class="btn btn-outline-primary btn-sm">
                                                <i class="bi bi-linkedin"></i> LinkedIn
                                            </a>
                                            <a href="https://mail.google.com/mail/?view=cm&fs=1&to=benpabia86@gmail.com" target="_blank"
                                                   class="btn btn-outline-secondary btn-sm">
                                                <i class="bi bi-envelope-fill"></i> Contact
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-5 pt-4 border-top text-center">
                                <h6 class="text-uppercase fw-bold text-muted small mb-3">Built With</h6>
                                <div class="d-flex justify-content-center gap-3">
                                    <span class="badge bg-light text-dark border p-2">ASP.NET Core MVC</span>
                                    <span class="badge bg-light text-dark border p-2">Entity Framework Core</span>
                                    <span class="badge bg-light text-dark border p-2">SQL Server</span>
                                    <span class="badge bg-light text-dark border p-2">Bootstrap 5</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>